from base import function_ai, parameters_func, property_param
import os
import platform
import time
import psutil
import json

__MONITOR_PROPERTY_ONE__ = property_param(
    name="metric",
    description="The system metric to monitor: 'cpu', 'memory', 'disk', 'network', 'processes', 'all'.",
    t="string",
)

__MONITOR_PROPERTY_TWO__ = property_param(
    name="interval",
    description="Sampling interval in seconds. Defaults to 1 second.",
    t="number",
)

__MONITOR_PROPERTY_THREE__ = property_param(
    name="duration",
    description="Monitoring duration in seconds. If not specified, returns single snapshot.",
    t="number",
)

__MONITOR_PROPERTY_FOUR__ = property_param(
    name="format",
    description="Output format: 'text' (human-readable), 'json' (machine-readable).",
    t="string",
)

__MONITOR_PROPERTY_FIVE__ = property_param(
    name="process_name",
    description="Process name to monitor (for process-specific metrics).",
    t="string",
)

__MONITOR_FUNCTION__ = function_ai(
    name="monitor",
    description="Monitor system resources (CPU, memory, disk, network, processes). Provides real-time system metrics.",
    parameters=parameters_func(
        [
            __MONITOR_PROPERTY_ONE__,
            __MONITOR_PROPERTY_TWO__,
            __MONITOR_PROPERTY_THREE__,
            __MONITOR_PROPERTY_FOUR__,
            __MONITOR_PROPERTY_FIVE__,
        ]
    ),
)

tools = [__MONITOR_FUNCTION__]


def get_cpu_info():
    """Get CPU information and usage."""
    try:
        cpu_percent = psutil.cpu_percent(interval=0.1)
        cpu_count = psutil.cpu_count()
        cpu_freq = psutil.cpu_freq()
        
        cpu_info = {
            "percent": cpu_percent,
            "count_logical": cpu_count,
            "count_physical": psutil.cpu_count(logical=False),
            "frequency_current": cpu_freq.current if cpu_freq else None,
            "frequency_min": cpu_freq.min if cpu_freq else None,
            "frequency_max": cpu_freq.max if cpu_freq else None,
            "load_average": psutil.getloadavg() if hasattr(psutil, 'getloadavg') else None,
            "per_cpu_percent": psutil.cpu_percent(interval=0.1, percpu=True),
        }
        
        return cpu_info
    except Exception as e:
        return {"error": f"Failed to get CPU info: {str(e)}"}


def get_memory_info():
    """Get memory information."""
    try:
        memory = psutil.virtual_memory()
        swap = psutil.swap_memory()
        
        memory_info = {
            "total": memory.total,
            "available": memory.available,
            "used": memory.used,
            "percent": memory.percent,
            "free": memory.free,
            "swap_total": swap.total,
            "swap_used": swap.used,
            "swap_free": swap.free,
            "swap_percent": swap.percent,
        }
        
        return memory_info
    except Exception as e:
        return {"error": f"Failed to get memory info: {str(e)}"}


def get_disk_info():
    """Get disk information."""
    try:
        disk_partitions = psutil.disk_partitions()
        disk_info = {}
        
        for partition in disk_partitions:
            try:
                usage = psutil.disk_usage(partition.mountpoint)
                disk_info[partition.mountpoint] = {
                    "device": partition.device,
                    "fstype": partition.fstype,
                    "total": usage.total,
                    "used": usage.used,
                    "free": usage.free,
                    "percent": usage.percent,
                }
            except (PermissionError, OSError):
                continue  # Skip partitions we can't access
        
        # Get disk I/O if available
        try:
            disk_io = psutil.disk_io_counters()
            if disk_io:
                disk_info["io"] = {
                    "read_count": disk_io.read_count,
                    "write_count": disk_io.write_count,
                    "read_bytes": disk_io.read_bytes,
                    "write_bytes": disk_io.write_bytes,
                    "read_time": disk_io.read_time,
                    "write_time": disk_io.write_time,
                }
        except:
            pass
        
        return disk_info
    except Exception as e:
        return {"error": f"Failed to get disk info: {str(e)}"}


def get_network_info():
    """Get network information."""
    try:
        net_io = psutil.net_io_counters()
        net_if_addrs = psutil.net_if_addrs()
        net_if_stats = psutil.net_if_stats()
        
        network_info = {
            "bytes_sent": net_io.bytes_sent,
            "bytes_recv": net_io.bytes_recv,
            "packets_sent": net_io.packets_sent,
            "packets_recv": net_io.packets_recv,
            "errin": net_io.errin,
            "errout": net_io.errout,
            "dropin": net_io.dropin,
            "dropout": net_io.dropout,
            "interfaces": {},
        }
        
        # Add interface details
        for interface in net_if_addrs:
            network_info["interfaces"][interface] = {
                "addresses": [
                    {
                        "family": str(addr.family),
                        "address": addr.address,
                        "netmask": addr.netmask if hasattr(addr, 'netmask') else None,
                        "broadcast": addr.broadcast if hasattr(addr, 'broadcast') else None,
                    }
                    for addr in net_if_addrs[interface]
                ],
                "is_up": net_if_stats[interface].isup if interface in net_if_stats else None,
                "speed": net_if_stats[interface].speed if interface in net_if_stats and hasattr(net_if_stats[interface], 'speed') else None,
            }
        
        return network_info
    except Exception as e:
        return {"error": f"Failed to get network info: {str(e)}"}


def get_process_info(process_name=None):
    """Get process information."""
    try:
        processes = []
        
        for proc in psutil.process_iter(['pid', 'name', 'cpu_percent', 'memory_percent', 'status', 'create_time']):
            try:
                process_info = proc.info
                
                # Filter by process name if specified
                if process_name and process_name.lower() not in process_info['name'].lower():
                    continue
                
                # Get more details
                with proc.oneshot():
                    try:
                        process_info['cmdline'] = proc.cmdline()
                    except (psutil.AccessDenied, psutil.NoSuchProcess):
                        process_info['cmdline'] = None
                    
                    try:
                        process_info['exe'] = proc.exe()
                    except (psutil.AccessDenied, psutil.NoSuchProcess):
                        process_info['exe'] = None
                    
                    try:
                        process_info['memory_info'] = {
                            'rss': proc.memory_info().rss,
                            'vms': proc.memory_info().vms,
                        }
                    except (psutil.AccessDenied, psutil.NoSuchProcess):
                        process_info['memory_info'] = None
                
                processes.append(process_info)
                
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        
        # Sort by CPU usage (descending)
        processes.sort(key=lambda x: x.get('cpu_percent', 0), reverse=True)
        
        return {"processes": processes, "count": len(processes)}
    except Exception as e:
        return {"error": f"Failed to get process info: {str(e)}"}


def get_system_info():
    """Get general system information."""
    try:
        system_info = {
            "platform": platform.platform(),
            "system": platform.system(),
            "release": platform.release(),
            "version": platform.version(),
            "architecture": platform.architecture(),
            "processor": platform.processor(),
            "hostname": platform.node(),
            "python_version": platform.python_version(),
            "boot_time": psutil.boot_time(),
            "users": [user._asdict() for user in psutil.users()] if hasattr(psutil, 'users') else [],
        }
        
        return system_info
    except Exception as e:
        return {"error": f"Failed to get system info: {str(e)}"}


def format_bytes(bytes_value):
    """Format bytes value to human-readable string."""
    if bytes_value is None:
        return "N/A"
    
    for unit in ['B', 'KB', 'MB', 'GB', 'TB']:
        if bytes_value < 1024.0:
            return f"{bytes_value:.2f} {unit}"
        bytes_value /= 1024.0
    return f"{bytes_value:.2f} PB"


def format_percent(percent):
    """Format percentage value."""
    if percent is None:
        return "N/A"
    return f"{percent:.1f}%"


def format_text_output(data, metric):
    """Format monitoring data as human-readable text."""
    output_lines = []
    
    if metric == "cpu" or metric == "all":
        if "cpu" in data or "error" in data.get("cpu", {}):
            output_lines.append("\n" + "="*60)
            output_lines.append("CPU INFORMATION")
            output_lines.append("="*60)
            
            cpu_data = data.get("cpu", {})
            if "error" in cpu_data:
                output_lines.append(f"Error: {cpu_data['error']}")
            else:
                output_lines.append(f"CPU Usage: {format_percent(cpu_data.get('percent'))}")
                output_lines.append(f"Logical CPUs: {cpu_data.get('count_logical')}")
                output_lines.append(f"Physical CPUs: {cpu_data.get('count_physical')}")
                
                if cpu_data.get('frequency_current'):
                    output_lines.append(f"Current Frequency: {cpu_data['frequency_current']:.2f} MHz")
                
                load_avg = cpu_data.get('load_average')
                if load_avg:
                    output_lines.append(f"Load Average (1, 5, 15 min): {load_avg[0]:.2f}, {load_avg[1]:.2f}, {load_avg[2]:.2f}")
    
    if metric == "memory" or metric == "all":
        if "memory" in data or "error" in data.get("memory", {}):
            output_lines.append("\n" + "="*60)
            output_lines.append("MEMORY INFORMATION")
            output_lines.append("="*60)
            
            memory_data = data.get("memory", {})
            if "error" in memory_data:
                output_lines.append(f"Error: {memory_data['error']}")
            else:
                output_lines.append(f"Total Memory: {format_bytes(memory_data.get('total'))}")
                output_lines.append(f"Available Memory: {format_bytes(memory_data.get('available'))}")
                output_lines.append(f"Used Memory: {format_bytes(memory_data.get('used'))} ({format_percent(memory_data.get('percent'))})")
                output_lines.append(f"Free Memory: {format_bytes(memory_data.get('free'))}")
                
                if memory_data.get('swap_total') > 0:
                    output_lines.append(f"\nSwap Total: {format_bytes(memory_data.get('swap_total'))}")
                    output_lines.append(f"Swap Used: {format_bytes(memory_data.get('swap_used'))} ({format_percent(memory_data.get('swap_percent'))})")
    
    if metric == "disk" or metric == "all":
        if "disk" in data or "error" in data.get("disk", {}):
            output_lines.append("\n" + "="*60)
            output_lines.append("DISK INFORMATION")
            output_lines.append("="*60)
            
            disk_data = data.get("disk", {})
            if "error" in disk_data:
                output_lines.append(f"Error: {disk_data['error']}")
            else:
                for mountpoint, info in disk_data.items():
                    if mountpoint == "io":
                        continue
                    
                    output_lines.append(f"\n{mountpoint} ({info.get('device')}, {info.get('fstype')})")
                    output_lines.append(f"  Total: {format_bytes(info.get('total'))}")
                    output_lines.append(f"  Used: {format_bytes(info.get('used'))} ({format_percent(info.get('percent'))})")
                    output_lines.append(f"  Free: {format_bytes(info.get('free'))}")
                
                if "io" in disk_data:
                    io_data = disk_data["io"]
                    output_lines.append(f"\nDisk I/O:")
                    output_lines.append(f"  Read: {format_bytes(io_data.get('read_bytes'))} ({io_data.get('read_count')} operations)")
                    output_lines.append(f"  Write: {format_bytes(io_data.get('write_bytes'))} ({io_data.get('write_count')} operations)")
    
    if metric == "network" or metric == "all":
        if "network" in data or "error" in data.get("network", {}):
            output_lines.append("\n" + "="*60)
            output_lines.append("NETWORK INFORMATION")
            output_lines.append("="*60)
            
            network_data = data.get("network", {})
            if "error" in network_data:
                output_lines.append(f"Error: {network_data['error']}")
            else:
                output_lines.append(f"Bytes Sent: {format_bytes(network_data.get('bytes_sent'))}")
                output_lines.append(f"Bytes Received: {format_bytes(network_data.get('bytes_recv'))}")
                output_lines.append(f"Packets Sent: {network_data.get('packets_sent')}")
                output_lines.append(f"Packets Received: {network_data.get('packets_recv')}")
    
    if metric == "processes" or metric == "all":
        if "processes" in data or "error" in data.get("processes", {}):
            output_lines.append("\n" + "="*60)
            output_lines.append("PROCESS INFORMATION")
            output_lines.append("="*60)
            
            processes_data = data.get("processes", {})
            if "error" in processes_data:
                output_lines.append(f"Error: {processes_data['error']}")
            else:
                processes = processes_data.get("processes", [])
                count = processes_data.get("count", 0)
                
                output_lines.append(f"Total Processes: {count}")
                output_lines.append(f"\nTop 10 processes by CPU usage:")
                output_lines.append(f"{'PID':>8} {'Name':<20} {'CPU%':>8} {'Mem%':>8} {'Status':<12}")
                output_lines.append("-" * 60)
                
                for proc in processes[:10]:
                    output_lines.append(
                        f"{proc.get('pid', 'N/A'):>8} "
                        f"{proc.get('name', 'N/A')[:19]:<20} "
                        f"{format_percent(proc.get('cpu_percent')):>8} "
                        f"{format_percent(proc.get('memory_percent')):>8} "
                        f"{proc.get('status', 'N/A')[:11]:<12}"
                    )
    
    if metric == "all":
        if "system" in data or "error" in data.get("system", {}):
            output_lines.append("\n" + "="*60)
            output_lines.append("SYSTEM INFORMATION")
            output_lines.append("="*60)
            
            system_data = data.get("system", {})
            if "error" in system_data:
                output_lines.append(f"Error: {system_data['error']}")
            else:
                output_lines.append(f"Platform: {system_data.get('platform')}")
                output_lines.append(f"Hostname: {system_data.get('hostname')}")
                output_lines.append(f"System: {system_data.get('system')} {system_data.get('release')}")
                output_lines.append(f"Architecture: {system_data.get('architecture')[0] if system_data.get('architecture') else 'N/A'}")
                output_lines.append(f"Python Version: {system_data.get('python_version')}")
                output_lines.append(f"Boot Time: {time.ctime(system_data.get('boot_time'))}")
    
    if not output_lines:
        return "No data collected. Check if psutil is installed and you have sufficient permissions."
    
    return "\n".join(output_lines)


def monitor(
    metric: str = "all",
    interval: float = 1.0,
    duration: float = None,
    format: str = "text",
    process_name: str = None,
) -> str:
    """
    Monitor system resources.
    
    Args:
        metric: The system metric to monitor
        interval: Sampling interval in seconds
        duration: Monitoring duration in seconds (None for single snapshot)
        format: Output format ('text' or 'json')
        process_name: Process name to monitor
    
    Returns:
        Monitoring results in specified format
    """
    try:
        # Check if psutil is available
        import psutil
    except ImportError:
        return "Error: psutil library is required for system monitoring. Install it with: pip install psutil"
    
    # Validate parameters
    valid_metrics = ["cpu", "memory", "disk", "network", "processes", "all"]
    if metric not in valid_metrics:
        return f"Error: Invalid metric '{metric}'. Valid options: {', '.join(valid_metrics)}"
    
    valid_formats = ["text", "json"]
    if format not in valid_formats:
        return f"Error: Invalid format '{format}'. Valid options: {', '.join(valid_formats)}"
    
    if interval <= 0:
        return "Error: Interval must be positive"
    
    if duration is not None and duration <= 0:
        return "Error: Duration must be positive"
    
    # Single snapshot or continuous monitoring
    if duration is None:
        # Single snapshot
        data = {}
        
        if metric in ["cpu", "all"]:
            data["cpu"] = get_cpu_info()
        
        if metric in ["memory", "all"]:
            data["memory"] = get_memory_info()
        
        if metric in ["disk", "all"]:
            data["disk"] = get_disk_info()
        
        if metric in ["network", "all"]:
            data["network"] = get_network_info()
        
        if metric in ["processes", "all"]:
            data["processes"] = get_process_info(process_name)
        
        if metric == "all":
            data["system"] = get_system_info()
        
        # Format output
        if format == "json":
            return json.dumps(data, indent=2, default=str)
        else:
            return format_text_output(data, metric)
    
    else:
        # Continuous monitoring
        samples = []
        end_time = time.time() + duration
        
        try:
            while time.time() < end_time:
                sample = {"timestamp": time.time()}
                
                if metric in ["cpu", "all"]:
                    sample["cpu"] = get_cpu_info()
                
                if metric in ["memory", "all"]:
                    sample["memory"] = get_memory_info()
                
                if metric in ["disk", "all"]:
                    # Only get disk info occasionally to avoid performance impact
                    if len(samples) % 5 == 0:
                        sample["disk"] = get_disk_info()
                
                if metric in ["network", "all"]:
                    sample["network"] = get_network_info()
                
                if metric in ["processes", "all"]:
                    # Only get process info occasionally
                    if len(samples) % 10 == 0:
                        sample["processes"] = get_process_info(process_name)
                
                samples.append(sample)
                
                # Sleep for interval, but check for end time
                sleep_time = min(interval, end_time - time.time())
                if sleep_time > 0:
                    time.sleep(sleep_time)
                else:
                    break
            
            # Format output
            if format == "json":
                return json.dumps({"samples": samples}, indent=2, default=str)
            else:
                # Summarize continuous monitoring
                output_lines = []
                output_lines.append(f"Continuous monitoring for {duration:.1f}s with {interval:.1f}s interval")
                output_lines.append(f"Collected {len(samples)} samples")
                output_lines.append("\n" + "="*60)
                
                # Add summary of first and last sample
                if samples:
                    output_lines.append("First sample summary:")
                    output_lines.append(format_text_output(samples[0], metric))
                    
                    if len(samples) > 1:
                        output_lines.append("\n" + "="*60)
                        output_lines.append("Last sample summary:")
                        output_lines.append(format_text_output(samples[-1], metric))
                
                return "\n".join(output_lines)
        
        except KeyboardInterrupt:
            return "Monitoring interrupted by user"
    
    except Exception as e:
        return f"Error during system monitoring: {str(e)}"


TOOL_CALL_MAP = {
    "monitor": monitor,
}